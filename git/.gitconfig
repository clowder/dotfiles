[alias]
    ci = commit
    co = checkout
    st = status
    br = rev-parse --abbrev-ref HEAD
    fush = push --force-with-lease

[core]
    excludesfile = ~/.gitignore_global
    precomposeUnicode = true

[color]
    branch = auto
    diff = auto
    status = auto

[branch]
    autosetuprebase = always
    sort = -committerdate

[tag]
    sort = version:refname

[init]
    defaultBranch = main

[commit]
    gpgsign = true

[gpg]
    format = ssh

[push]
    autoSetupRemote = true
    followTags = true # auto-push annotated tags with their commits

[fetch]
    prune = true
    pruneTags = true

[rerere]
    enabled = true    # reuse recorded conflict resolutions
    autoupdate = true # auto-stage resolved files

[rebase]
    autoSquash = true # auto-reorder fixup!/squash!/amend! commits

[include]
    path = ~/.gitconfig_local
