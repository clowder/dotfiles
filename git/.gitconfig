[user]
    name = Chris Lowder
    email = clowder@users.noreply.github.com
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINMTgGfyXQe9yNrLqkACu2kiaMk2M/Cdo+4N1FCH9DDT

[github]
    user = clowder

[gpg]
    format = ssh

[gpg "ssh"]
    program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[alias]
    ci = commit
    co = checkout
    st = status
    br = rev-parse --abbrev-ref HEAD
    fush = push --force-with-lease

[core]
    excludesfile = ~/.gitignore_global
    precomposeUnicode = true

[protocol "ext"]
    allow = never # Block transport helpers that can execute arbitrary shell via URL

[protocol "fd"]
    allow = never # Block transport helpers that can execute arbitrary shell via URL

[color]
    branch = auto
    diff = auto
    status = auto

[branch]
    autosetuprebase = always
    sort = -committerdate

[tag]
    sort = version:refname

[init]
    defaultBranch = main

[commit]
    gpgsign = true

[push]
    autoSetupRemote = true
    followTags = true # auto-push annotated tags with their commits

[fetch]
    prune = true
    pruneTags = true

[rerere]
    enabled = true    # reuse recorded conflict resolutions
    autoupdate = true # auto-stage resolved files

[rebase]
    autoSquash = true # auto-reorder fixup!/squash!/amend! commits

[include]
    path = ~/.gitconfig_local
