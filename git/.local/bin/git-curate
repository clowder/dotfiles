#!/usr/bin/env bash
set -euo pipefail

# Colors
readonly DIM=$'\033[2m'
readonly BOLD=$'\033[1m'
readonly YELLOW=$'\033[33m'
readonly RESET=$'\033[0m'

# Terminal state
saved_tty=""
LINES=24
COLUMNS=80

teardown_tui() {
  [[ -n "$saved_tty" ]] || return 0
  printf '\e[?25h\e[?1049l'  # show cursor, exit alternate screen
  stty "$saved_tty" 2>/dev/null
  saved_tty=""
}

trap teardown_tui EXIT

get_term_size() {
  read -r LINES COLUMNS < <(stty size)
}

# Gather branch data
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD)

# Merged branches
declare -A merged_set
while IFS= read -r b; do merged_set[$b]=1; done < <(git branch --merged HEAD --format='%(refname:short)')

# Single git call gathers all per-branch metadata.
# subject is last because it may contain tabs.
while IFS=$'\x1f' read -r b upstream track info; do
  [[ "$b" != "$current_branch" ]] || continue

  branches+=("$b")
  commit_info+=("$info")

  if [[ -z "$upstream" ]]; then
    upstream_status+=("none")
  elif [[ -z "$track" ]]; then
    upstream_status+=("up-to-date")
  else
    upstream_status+=("${track//[\[\]]/}")
  fi

  checked+=( 0 )
done < <(git for-each-ref \
  --format="%(refname:short)"$'\x1f'"%(upstream:short)"$'\x1f'"%(upstream:track)"$'\x1f'"%(objectname:short) %(subject) (%(creatordate:relative))" \
  --sort=committerdate refs/heads/)

if [[ ${#branches[@]} -eq 0 ]]; then
  printf 'No other branches to curate.\n'
  exit 0
fi

# Static column widths (display columns, not bytes)
max_branch=6
max_merged=6
max_upstream=8
for i in "${!branches[@]}"; do
  if (( ${#branches[$i]} > max_branch )); then max_branch=${#branches[$i]}; fi
  if (( ${#upstream_status[$i]} > max_upstream )); then max_upstream=${#upstream_status[$i]}; fi
done

# TUI state
cursor=0

# Pad a string to exactly W characters, truncating if needed.
pad() {
  local -n _out=$1
  local str=$2 width=$3
  local len=${#str}
  if (( len >= width )); then
    _out=${str:0:width}
  else
    printf -v _out '%-*s' "$width" "$str"
  fi
}

render() {
  local i
  get_term_size

  # Compute column positions once per render
  local commit_width=$((COLUMNS - 11 - max_branch - max_merged - max_upstream))
  if (( commit_width < 11 )); then commit_width=11; fi
  local merged_start=$((5 + max_branch + 2 + commit_width + 2))
  local upstream_start=$((merged_start + max_merged + 2))
  local move_merged=$'\e['"${merged_start}"'G'
  local move_upstream=$'\e['"${upstream_start}"'G'

  # Header at line 1
  local col_branch col_commit
  local col_prefix="     "
  pad col_branch "Branch" "$max_branch"
  pad col_commit "Last commit" "$commit_width"
  printf '\e[1;1H\e[2K%s%s%s' "$DIM" "${col_prefix}${col_branch}  ${col_commit}${move_merged}Merged${move_upstream}Upstream" "$RESET"

  # Branch rows starting at line 2
  local visible=$((LINES - 2))
  for i in "${!branches[@]}"; do
    if (( i >= visible )); then break; fi

    local prefix="[ ]  "
    if (( checked[i] )); then prefix="[x]  "; fi

    pad col_prefix "$prefix" 5
    pad col_branch "${branches[$i]}" "$max_branch"
    pad col_commit "${commit_info[$i]}" "$commit_width"
    local merged; if [[ -v "merged_set[${branches[$i]}]" ]]; then merged="yes"; else merged="no"; fi
    local row="${col_prefix}${col_branch}  ${col_commit}${move_merged}${merged}${move_upstream}${upstream_status[$i]}"

    printf '\e[%s;1H\e[2K' "$((i + 2))"
    if (( i == cursor )); then
      printf '%s%s%s' "$BOLD" "$row" "$RESET"
    else
      printf '%s' "$row"
    fi
  done

  printf '\e[J'  # erase to end of screen

  # Status bar at last line
  printf '\e[%s;1H\e[2K%s j/↓ k/↑ move  x/<Space> toggle  D delete  q/<Esc> quit %s' "$LINES" "$DIM" "$RESET"
}

read_key() {
  local -n _key=$1
  local char
  IFS= read -rsn1 char
  if [[ "$char" == $'\x1b' ]]; then
    local seq
    IFS= read -rsn2 -t 0.01 seq || true
    if [[ -z "$seq" ]]; then
      _key=ESC
      return
    fi
    case "$seq" in
      '[A') _key=UP ;;
      '[B') _key=DOWN ;;
      *)    _key=IGNORE ;;
    esac
    return
  fi
  _key=$char
}

do_delete() {
  local i
  teardown_tui

  local selected=()
  for i in "${!branches[@]}"; do
    if (( checked[i] )); then selected+=("${branches[$i]}"); fi
  done

  if [[ ${#selected[@]} -eq 0 ]]; then
    printf 'No branches selected.\n'
    exit 0
  fi

  printf 'Branches to delete:\n'
  for b in "${selected[@]}"; do
    printf '  %s\n' "$b"
  done
  printf '\n'

  printf 'Are you sure? [y/n] '
  read -r confirm
  if [[ "${confirm,,}" != y ]]; then
    printf 'Aborted.\n'
    exit 0
  fi

  for b in "${selected[@]}"; do
    # Check if branch is checked out in a worktree
    local wt_path=""
    wt_path=$(git worktree list --porcelain | awk -v branch="$b" '
      /^worktree / { wt = substr($0, 10) }
      /^branch / { if (substr($0, 8) == "refs/heads/" branch) print wt }
    ')

    if [[ -n "$wt_path" ]]; then
      if ! git worktree remove "$wt_path" 2>&1; then
        printf '%sWarning: could not remove worktree for %s, skipping%s\n' "$YELLOW" "$b" "$RESET"
        continue
      fi
    fi

    if git merge-base --is-ancestor "$b" HEAD 2>/dev/null; then
      if ! git branch -d "$b" 2>&1; then
        printf '%sWarning: could not delete %s%s\n' "$YELLOW" "$b" "$RESET"
      fi
    else
      printf 'Force-deleting unmerged branch %s\n' "$b"
      if ! git branch -D "$b" 2>&1; then
        printf '%sWarning: could not delete %s%s\n' "$YELLOW" "$b" "$RESET"
      fi
    fi
  done

  exit 0
}

# Enter TUI
saved_tty=$(stty -g)
get_term_size
printf '\e[?1049h\e[?25l'  # alternate screen, hide cursor
stty raw -echo

while true; do
  render
  key=""
  read_key key
  case "$key" in
    j|DOWN)
      if (( cursor < ${#branches[@]} - 1 )); then cursor=$((cursor + 1)); fi
      ;;
    k|UP)
      if (( cursor > 0 )); then cursor=$((cursor - 1)); fi
      ;;
    x|' ')
      (( checked[cursor] ^= 1 )) || true
      ;;
    D)
      do_delete
      ;;
    q|ESC)
      exit 0
      ;;
  esac
done
