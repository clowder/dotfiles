{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(~/.claude/plans/**)",
      "Read(~/.go/pkg/mod/**)",
      "Read(~/.mise/installs/ruby/**)",
      "WebSearch(*)",
      "WebFetch(domain:docs.stripe.com)",
      "WebFetch(domain:pkg.go.dev)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(file:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(bundle exec rake -T:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec standardrb:*)",
      "Bash(bundle exec brakeman:*)",
      "Bash(bundle info:*)",
      "Bash(bundle list:*)",
      "Bash(bundle show:*)",
      "Bash(bin/rails db:migrate:*)",
      "Bash(bin/rails generate:*)",
      "Bash(bin/rails routes:*)",
      "Bash(bin/rails setup:*)",
      "Bash(bin/rails spec:*)",
      "Bash(bin/rails standard:*)",
      "Bash(bin/rails test:*)",
      "Bash(bin/rspec:*)",
      "Bash(bin/brakeman:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh search:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash apply:*)",
      "Bash(git stash list:*)",
      "Bash(git stash push:*)",
      "Bash(git stash show:*)",
      "Bash(git rev-parse:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go fix:*)",
      "Bash(go fmt:*)",
      "Bash(go list:*)",
      "Bash(go mod graph)",
      "Bash(go mod tidy)",
      "Bash(go test:*)",
      "Bash(go version:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(shellcheck:*)",
      "Read(~/llm-wiki/**)",
      "Write(~/llm-wiki/**)",
      "Edit(~/llm-wiki/**)",
      "Bash(git -C ~/llm-wiki add:*)",
      "Bash(git -C ~/llm-wiki commit:*)"
    ],
    "defaultMode": "default"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "gitAttribution": false
}
